# 環境変数のサンプル
# このファイルをコピーして .env を作成してください
#   cp .env.example .env
#
# 注意:
#   - Vite では VITE_ プレフィックスの付いた変数のみがクライアントコードに露出します
#     （import.meta.env.VITE_xxx で参照）
#   - 秘密鍵など漏らしたくない値には VITE_ を付けないでください
#   - .env は .gitignore で除外されています（このファイルだけコミット可）

# API のベース URL
VITE_API_BASE_URL=http://localhost:8000

# アプリ表示名
VITE_APP_TITLE=React Sample Template
